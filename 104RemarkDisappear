// ==UserScript==
// @name         104 Hide Resume Cards With Remarks Or Recent Outreach
// @namespace    local-104-filter
// @version      1.5
// @description  Hide 104 resume cards with remarks or recent history containing active outreach within 3 months
// @match        https://*.104.com.tw/*
// @run-at       document-idle
// ==/UserScript==

(function () {
  'use strict';

  const MONTHS_TO_HIDE = 3;

  function getCutoffDate() {
    const cutoff = new Date();
    cutoff.setMonth(cutoff.getMonth() - MONTHS_TO_HIDE);
    cutoff.setHours(0, 0, 0, 0);
    return cutoff;
  }

  function parseHistoryDate(text) {
    const match = text.match(/(\d{4})\/(\d{2})\/(\d{2})\s+(\d{2}):(\d{2})/);

    if (!match) return null;

    const [, year, month, day, hour, minute] = match;

    return new Date(
      Number(year),
      Number(month) - 1,
      Number(day),
      Number(hour),
      Number(minute)
    );
  }

  function isActiveOutreach(text) {
    return text.includes('發出');
  }

  function hasRecentActiveOutreach(card) {
    const cutoffDate = getCutoffDate();
    const historyItems = card.querySelectorAll(
      '.history-list__collapse .list-txt'
    );

    return Array.from(historyItems).some(item => {
      const text = item.textContent || '';
      const historyDate = parseHistoryDate(text);

      return (
        isActiveOutreach(text) &&
        historyDate &&
        historyDate >= cutoffDate
      );
    });
  }

  function hideCard(card) {
    card.style.setProperty('display', 'none', 'important');
  }

  function filterResumeCards() {
    const cards = document.querySelectorAll('.vip-resume-card.resume-card');

    cards.forEach(card => {
      const hasRemark = card.querySelector('.resume-remark.mt-2');
      const hasRecentOutreach = hasRecentActiveOutreach(card);

      if (hasRemark || hasRecentOutreach) {
        hideCard(card);
      }
    });
  }

  filterResumeCards();

  const observer = new MutationObserver(filterResumeCards);

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
})();
